@model CinemaSystem.Models.Movie

<div class="container mt-5">

    <div class="row">

        <!-- 🎥 Movie Image -->
        <div class="col-md-4">
            <img src="@Url.Content("~/images/movies/" + Model.MainImg)"
                 class="img-fluid rounded shadow"
                 alt="@Model.Name">
        </div>

        <!-- 🎬 Movie Info -->
        <div class="col-md-8">

            <h2 class="mb-3">@Model.Name</h2>

            <!-- Status -->
            <span class="badge @(Model.Status ? "bg-success" : "bg-danger")">
                @(Model.Status ? "Now Showing" : "Not Available")
            </span>

            <!-- Description -->
            <p class="mt-3 text-muted">
                @(string.IsNullOrEmpty(Model.Des) ? "No description available." : Model.Des)
            </p>

            <!-- Info Card -->
            <div class="card shadow-sm mt-3">
                <div class="card-body">

                    <p><strong>💰 Price:</strong> @Model.Price EGP</p>

                    <p>
                        <strong>📅 Release Date:</strong>
                        @Model.DateTime.ToString("yyyy-MM-dd")
                    </p>

                </div>
            </div>

            <!-- 🎞 Trailer -->
            @if (!string.IsNullOrEmpty(Model.Trailer))
            {
                <div class="mt-4">
                    <h5>🎥 Trailer</h5>
                    <div class="ratio ratio-16x9">
                        <iframe src="@Model.Trailer"
                                title="Trailer"
                                allowfullscreen>
                        </iframe>
                    </div>
                </div>
            }

            <!-- 🎭 Actors -->
            @if (Model.MovieActors.Any())
            {
                <div class="mt-4">
                    <h5>🎭 Actors</h5>
                    <ul class="list-group">
                        @foreach (var actor in Model.MovieActors)
                        {
                            <li class="list-group-item">
                                @actor.Actor?.Name
                            </li>
                        }
                    </ul>
                </div>
            }

            <!-- 🎬 Cinemas -->
            @if (Model.MovieCinemas.Any())
            {
                <div class="mt-4">
                    <h5>🏢 Available In Cinemas</h5>
                    <ul class="list-group">
                        @foreach (var cinema in Model.MovieCinemas)
                        {
                            <li class="list-group-item">
                                @cinema.Cinema?.Name
                            </li>
                        }
                    </ul>
                </div>
            }

            <!-- 🎯 Categories -->
            @if (Model.MovieCategories.Any())
            {
                <div class="mt-4">
                    <h5>🎯 Categories</h5>

                    @foreach (var cat in Model.MovieCategories)
                    {
                        <span class="badge bg-primary me-1">
                            @cat.Category?.Name
                        </span>
                    }
                </div>
            }

            <!-- 🔙 Buttons -->
            @{
                var shows = ViewBag.Shows as List<CinemaSystem.Models.Show>;
            }

            <div class="mt-4">
                <h5>🎬 Available Shows</h5>

                @if (shows != null && shows.Any())
                {
                    @foreach (var show in shows)
                    {
                        <div class="border p-2 mb-2 rounded">
                            <p>
                                🏢 @show.Cinema.Name <br />
                                ⏰ @show.StartTime.ToString("g")
                            </p>

                            <a asp-controller="Home"
                                   asp-action="Book"
                                   asp-route-showId="@show.Id"
                                   class="btn btn-success">
                                🎟 Book Now
                            </a>
                        </div>
                    }
                }
                else
                {
                    <p>No shows available</p>
                }
            </div>

        </div>
    </div>

    <!-- 🖼 Sub Images -->
    @if (Model.SubImages.Any())
    {
        <div class="mt-5">
            <h4>📸 Gallery</h4>

            <div class="row">
                @foreach (var img in Model.SubImages)
                {
                    <div class="col-md-3 mb-3">
                        <img src="@Url.Content("~/images/movies/" + img.ImgUrl)"
                             class="img-fluid rounded shadow-sm">
                    </div>
                }
            </div>
        </div>
    }

</div>