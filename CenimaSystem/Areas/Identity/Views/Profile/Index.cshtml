@model ApplicationUserVM

<div class="container my-3">
    <div class="row gutters">
        <div class="col-xl-3 col-lg-3 col-md-12 col-sm-12 col-12">
            <div class="card h-100">
                <div class="card-body">
                    <div class="account-settings">
                        <div class="user-profile">
                            <div class="user-avatar mb-3">
                                <img src="https://bootdey.com/img/Content/avatar/avatar7.png" style="width: 70%" alt="Maxwell Admin">
                            </div>
                            <h5 class="user-name">"@Model.FirstName @Model.LastName"</h5>
                            <h6 class="user-email">@Model.Email</h6>
                        </div>
                        <div class="about">
                            <h5>About</h5>
                            <p>I'm "@Model.FirstName @Model.LastName".</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-9 col-lg-9 col-md-12 col-sm-12 col-12">
            <form asp-action="Update">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="row gutters">
                            <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                                <h6 class="mb-2 text-primary">Personal Details</h6>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label for="fullName">First Name</label>
                                    <input asp-for="FirstName" class="form-control" placeholder="Enter First name" />
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label for="fullName">Last Name</label>
                                    <input asp-for="LastName" class="form-control"  placeholder="Enter Last name" >
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label for="eMail">Email</label>
                                        <input asp-for="Email" class="form-control"  placeholder="Enter email ID" >
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label for="phone">Phone</label>
                                       <input asp-for="PhoneNumber" class="form-control"  placeholder="Enter phone number" >
                                </div>
                            </div>
                        </div>
                        <div class="row gutters">
                            <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                                <h6 class="mt-3 mb-2 text-primary">Address</h6>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label for="Address">Address</label>
                                    <input asp-for="Address" class="form-control"  placeholder="Enter Address" >
                                </div>
                            </div>
                        </div>
                        <div class="row gutters my-3">
                            <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                                <div class="text-right">
                                    <input type="reset" value="reset" id="submit" name="submit" class="btn btn-secondary">
                                    <input type="submit" value="Update" id="submit" name="submit" class="btn btn-primary">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="col-xl-9 col-lg-9 col-md-12 col-sm-12 col-12">
            <form asp-action="UpdatePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="card h-100">
                    <div class="card-body">
                        <div class="row gutters">
                            <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                                <h6 class="mb-2 text-primary"> Change Password </h6>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Old Password</label>
                                <input type="password" name="OldPassword" class="form-control" />
                                <span class="text-danger">@Html.ValidationMessage("OldPassword")</span>

                            </div>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                            <div class="form-group">
                                <label>New Password</label>
                                <input type="password" name="NewPassword" class="form-control" />
                                <span class="text-danger">@Html.ValidationMessage("NewPassword")</span>
                            </div>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label>Confirm Password</label>
                                    <input type="password" name="ConfirmPassword" class="form-control" />
                                    <span class="text-danger">@Html.ValidationMessage("ConfirmPassword")</span>
                                </div>
                            </div>

                        </div>
                       
                        <div class="row gutters my-3">
                            <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                                <div class="text-right">
                                    
                                      <button type="reset" class="btn btn-secondary">reset</button>
                                     <button type="submit" class="btn btn-primary">Update</button>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
                    @{
                        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    <partial name="_NotificationPartial" />
                    }


                }
