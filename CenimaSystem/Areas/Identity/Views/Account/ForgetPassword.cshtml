@model CinemaSystem.ViewModels.ForgetPasswordVM

@{
    ViewData["Title"] = "ForgetPassword";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container my-3">

<h1>ForgetPassword</h1>

<h4>ForgetPasswordVM</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="ForgetPassword">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="EmailOrUserName" class="control-label"></label>
                <input asp-for="EmailOrUserName" class="form-control" />
                <span asp-validation-for="EmailOrUserName" class="text-danger"></span>
            </div>
                <div class="form-group mt-3">
                <input type="submit" value="Send OTP" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Login">Back to Login</a>
</div>
<div>
    <a asp-action="Register">Register</a>
</div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotificationPartial">
    }
